pipeline {
  agent {
    docker {
      image 'parellishyamsunder/maven-docker-agent:v1'
      //args '--user root -v /var/run/docker.sock:/var/run/docker.sock' // mount Docker socket to access the host's Docker daemon
      args "-u root -v /var/run/docker.sock:/var/run/docker.sock -v /root/.m2:/root/.m2 --entrypoint=''"
    }
  }
  environment {
        DOCKER_HUB_USER = "parellishyamsunder"
        APP_NAME        = "ultimate-jenkins-cicd"
        SONAR_URL       = "http://52.66.140.114:9000"
        GIT_REPO        = "github.com/shyamkeshav/java-app-jenkins"
    }
  stages {
    stage('Checkout') {
      steps {
        sh 'echo passed' 
      }
    }
    stage('Build & Test') {
            steps {
                // Use dir() instead of 'cd' inside folder
                dir('spring-boot-app') {
                    sh 'mvn clean package -DskipTests=false'
                }
            }
        }
    stage('Static Code Analysis') {
            steps {
                withCredentials([string(credentialsId: 'sonarqube-token', variable: 'SONAR_TOKEN')]) {
                    dir('spring-boot-app') {
                        sh "mvn sonar:sonar -Dsonar.login=${SONAR_TOKEN} -Dsonar.host.url=${SONAR_URL}"
                    }
                }
            }
        }
    stage('Build & Push Docker Image') {
            steps {
                script {
                    def imageTag = "${DOCKER_HUB_USER}/${APP_NAME}:${BUILD_NUMBER}"
                    dir('spring-boot-app') {
                        // Use the Jenkins Docker DSL for cleaner syntax
                        def app = docker.build(imageTag)
                        docker.withRegistry('https://index.docker.io/v1/', 'docker-cred') {
                            app.push()
                            app.push("latest") // Industry standard to also push 'latest'
                        }
                    }
                }
            }
        }    
    
    stage('Cleanup Server') {
    steps {
        script {
            sh "docker rmi ${DOCKER_HUB_USER}/${APP_NAME}:${BUILD_NUMBER} || true"
            sh "docker rmi ${DOCKER_HUB_USER}/${APP_NAME}:latest || true"
            sh "docker image prune -f"
        }
    }
    }
    stage('Update Deployment File') {
    environment {
        GIT_REPO_NAME = "java-app-jenkins"
        GIT_USER_NAME = "shyamkeshav"
    }
    steps {
        withCredentials([string(credentialsId: 'github-token', variable: 'GITHUB_TOKEN')]) {
            // Use double quotes """ to allow Jenkins to pass variables to the shell
            sh """
                git config --global --add safe.directory ${WORKSPACE}
                git config user.email "shyam.xyz@gmail.com"
                git config user.name "shyam sunder"
                
                git checkout main

                # This regex finds the image line and replaces the tag at the end, 
                # regardless of what the previous build number was.
                sed -i "s|image: .*|        image: ${DOCKER_HUB_USER}/${APP_NAME}:${BUILD_NUMBER}|g" spring-boot-app-manifests/deployment.yml
                
                git add spring-boot-app-manifests/deployment.yml
                
                # Only commit if there is actually a change
                if ! git diff --cached --quiet; then
                    git commit -m "Update deployment image to version ${BUILD_NUMBER}"
                    git push https://\${GITHUB_TOKEN}@github.com/${GIT_USER_NAME}/${GIT_REPO_NAME} HEAD:main
                else
                    echo "No changes to commit"
                fi
            """
        }
    }
}    
  }
  post {
        always {
            cleanWs() // Best Practice: Always clean the workspace after a build
        }
        failure {
            echo "Pipeline failed. Check SonarQube or Docker logs."
        }
    }
}
