pipeline {
  agent {
    docker {
      image 'parellishyamsunder/maven-docker-agent:v1'
      //args '--user root -v /var/run/docker.sock:/var/run/docker.sock' // mount Docker socket to access the host's Docker daemon
      args "-u root -v /var/run/docker.sock:/var/run/docker.sock -v /root/.m2:/root/.m2 --entrypoint=''"
    }
  }
  environment {
        DOCKER_HUB_USER = "parellishyamsunder"
        APP_NAME        = "ultimate-jenkins-cicd"
        SONAR_URL       = "http://52.66.140.114:9000"
        GIT_REPO        = "github.com/shyamkeshav/java-app-jenkins"
    }
  stages {
    stage('Checkout') {
      steps {
        sh 'echo passed' 
      }
    }
    stage('Build & Test') {
            steps {
                // Use dir() instead of 'cd' inside folder
                dir('spring-boot-app') {
                    sh 'mvn clean package -DskipTests=false'
                }
            }
        }
    stage('Static Code Analysis') {
            steps {
                withCredentials([string(credentialsId: 'sonarqube-token', variable: 'SONAR_TOKEN')]) {
                    dir('spring-boot-app') {
                        sh "mvn sonar:sonar -Dsonar.login=${SONAR_TOKEN} -Dsonar.host.url=${SONAR_URL}"
                    }
                }
            }
        }
    stage('Build & Push Docker Image') {
            steps {
                script {
                    def imageTag = "${DOCKER_HUB_USER}/${APP_NAME}:${BUILD_NUMBER}"
                    dir('spring-boot-app') {
                        // Use the Jenkins Docker DSL for cleaner syntax
                        def app = docker.build(imageTag)
                        docker.withRegistry('https://index.docker.io/v1/', 'docker-cred') {
                            app.push()
                            app.push("latest") // Industry standard to also push 'latest'
                        }
                    }
                }
            }
        }    

    stage('Update GitOps Manifest') {
    steps {
        withCredentials([string(credentialsId: 'github-token', variable: 'GITHUB_TOKEN')]) {
            sh """
                # 1. Setup safety and identity
                git config --global --add safe.directory ${WORKSPACE}
                git config user.email "jenkins@yourdomain.com"
                git config user.name "Jenkins CI"

                # 2. Switch from 'detached HEAD' to the main branch
                git checkout main

                # 3. Update the manifest
                sed -i "s|image: .*${APP_NAME}:.*|image: ${DOCKER_HUB_USER}/${APP_NAME}:${BUILD_NUMBER}|g" spring-boot-app-manifests/deployment.yml
                
                # 4. Debug: Show the change in the logs
                echo "Checking manifest change:"
                grep "image:" spring-boot-app-manifests/deployment.yml

                # 5. Commit and Push only if changes exist
                if git diff --quiet spring-boot-app-manifests/deployment.yml; then
                    echo "No changes detected in manifest. Skipping git push."
                else
                    git add spring-boot-app-manifests/deployment.yml
                    git commit -m "chore: update image to version ${BUILD_NUMBER} [skip ci]"
                    # Use the environment variable safely to avoid the Groovy warning
                    git push https://\${GITHUB_TOKEN}@${GIT_REPO} main
                fi
            """
        }
    }
}
    stage('Cleanup Server') {
            // We use 'always' logic inside a stage to guarantee it runs
            steps {
                script {
                    echo "--- Stage : Automatic Cleanup ---"
                    // These commands clean the t3.medium regardless of previous stage results
                    sh "docker rmi ${DOCKER_HUB_USER}:${IMAGE_TAG} || true"
                    sh "docker rmi ${DOCKER_HUB_USER}:latest || true"
                    sh "docker logout ghcr.io || true"
                    sh "docker image prune -f"
                }
            }
        }    
  }
  post {
        always {
            cleanWs() // Best Practice: Always clean the workspace after a build
        }
        failure {
            echo "Pipeline failed. Check SonarQube or Docker logs."
        }
    }
}
